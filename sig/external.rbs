# Minimal stubs for external APIs we use.
# We don't aim to type-check OpenTelemetry / Ruby::Box themselves; we just
# tell Steep they exist so our own code can reference them.

module OpenTelemetry
  def self.tracer_provider: () -> untyped
  def self.propagation: () -> untyped

  module SDK
    def self.configure: () ?{ (untyped) -> void } -> void
  end

  module Trace
    module Status
      UNSET: Integer
      OK: Integer
      ERROR: Integer

      def self.error: (String?) -> untyped
    end

    def self.context_with_span: (untyped span) -> untyped
  end

  module Context
    def self.current: () -> untyped
    def self.with_current: [T] (untyped context) { () -> T } -> T
  end
end

module Ruby
  class Box
    def self.enabled?: () -> bool
    def self.new: () -> Box
    def eval: (String) -> untyped
    def require: (String) -> untyped
    def require_relative: (String) -> untyped
    def load: (String) -> untyped
  end
end

# Minimal stubs for the slice of ActiveSupport / ActiveJob that
# Sashiko::Rails actually touches. We do NOT aim to type-check Rails;
# we declare just enough so Steep can verify our integration code.

module ActiveSupport
  module Notifications
    def self.subscribe: (Regexp | String pattern) { (String name, Time start, Time finish, String id, Hash[untyped, untyped] payload) -> void } -> untyped
  end
end

module ActiveJob
  class Base
    def self.around_perform: () { (ActiveJob::Base job, Proc proc) [self: ActiveJob::Base] -> void } -> untyped
    def serialize: () -> Hash[String, untyped]
    def deserialize: (Hash[String, untyped] job_data) -> void
  end
end
